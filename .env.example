# Sēlah Express backend — copy to .env.local and fill in.
# These are read server-side only; never prefix with NEXT_PUBLIC_.

# Base URL of the existing Sēlah API on Render (no trailing slash).
SELAH_API_URL=https://your-selah-api.onrender.com

# Bearer token / service key, if the API requires auth. Leave blank if not.
SELAH_API_TOKEN=
