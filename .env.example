# Sēlah Express backend — copy to .env.local and fill in.
# These are read server-side only; never prefix with NEXT_PUBLIC_.

# Base URL of the existing Sēlah API on Render (no trailing slash).
SELAH_API_URL=https://your-selah-api.onrender.com

# Bearer token / service key, if the API requires auth. Leave blank if not.
SELAH_API_TOKEN=

# Secret that signs session JWTs. Generate: openssl rand -hex 32
SESSION_SECRET=

# --- Object storage (S3-compatible: AWS S3 / Cloudflare R2) ---
# Vision-board uploads are signed here and PUT directly to the bucket.
# Leave these unset to use the local dev receiver (public/uploads).
S3_BUCKET=
S3_REGION=auto                 # e.g. us-east-1 for AWS; "auto" for R2
S3_ENDPOINT=                   # set for R2/MinIO; omit for AWS S3
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=            # public origin objects are served from
